{:paths ["src" "resources"]
 :deps {}

 :aliases
 ;; Interactive nREPL server. Start with: clojure -M:nrepl       (src + resources)
 ;; Full dev classpath (test + dev too):  clojure -M:nrepl:dev
 ;; Agents then evaluate via clj-nrepl-eval against the discovered .nrepl-port.
 ;; See ../agent/ledger/2026-06-16-clojure-repl-light-workflow.md
 {:nrepl
  {:extra-deps {nrepl/nrepl {:mvn/version "1.5.1"}}
   :main-opts ["-m" "nrepl.cmdline"]}

  ;; Dev sources on the classpath (the dogfood app + tests), so an nREPL can
  ;; require/reload them interactively. Compose with :nrepl — `:nrepl:dev`.
  ;; test.check here too, so the generative property test loads in a REPL.
  :dev
  {:extra-paths ["test" "dev"]
   :extra-deps {org.clojure/test.check {:mvn/version "1.1.1"}}}

  ;; Test sources + runner (wired up once we have tests).
  :test
  {:extra-paths ["test"]
   :extra-deps {io.github.cognitect-labs/test-runner
                {:git/tag "v0.5.1" :git/sha "dfb30dd"}
                org.clojure/test.check {:mvn/version "1.1.1"}}
   :main-opts ["-m" "cognitect.test-runner"]}

  ;; Adapter smoke test (OPT-IN, run infrequently). The core :test suite stays
  ;; dependency-free; this alias is the ONLY place dj.concurrency is pulled onto
  ;; the classpath (git-SHA dep — not yet on Clojars), and it scans only the
  ;; isolated `test-adapter/` path so `dj.recorder.adapter.concurrency` — which
  ;; requires dj.concurrency — never breaks the core run.  Run with:
  ;;   clojure -M:adapter
  :adapter
  {:extra-paths ["test-adapter"]
   :extra-deps {io.github.bmillare/dj.concurrency
                {:git/sha "090cb2bdcaee709fbc5f934d4b3d0d187e2492e6"}
                io.github.cognitect-labs/test-runner
                {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
   :main-opts ["-m" "cognitect.test-runner" "-d" "test-adapter"]}}}
